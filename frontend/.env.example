# =============================================================================
# Adaptive Forecasting — Frontend Environment Variables
# =============================================================================
# Copy this file to `.env.local` for local development.
# When deploying, set these variables in your hosting provider's dashboard
# (e.g. Vercel → Project Settings → Environment Variables) at build time.
# =============================================================================

# URL of the deployed backend API server (no trailing slash).
#
# Local development:
#   Leave this unset (or comment it out). The Vite dev server will
#   proxy requests from /api/* to http://localhost:8000 automatically.
#   If you want to point your local dev build at a different backend,
#   uncomment and set the value below.
#
# Production (Vercel or any other host):
#   Set this to the full URL of your backend deployment, e.g.:
#     VITE_API_URL=https://adaptive-forecasting-backend.vercel.app
#
# NOTE: Vite only exposes variables prefixed with VITE_ to client-side code.
#       This variable is embedded into the static bundle at build time, so you
#       MUST redeploy the frontend whenever this value changes.
#
# VITE_API_URL=http://localhost:8000

VITE_INTERNAL_API_KEY=1234
